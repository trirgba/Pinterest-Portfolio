rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Cho phép mọi người có thể xem danh sách project và ảnh
      allow read: if true;
      
      // Chỉ cho phép thao tác thêm, sửa, xoá đối với 2 email quản trị viên
      allow write: if request.auth != null &&
        request.auth.token.email in [
          "mintri.arena@gmail.com",
          "trixinchao@gmail.com"
        ];
    }
  }
}
